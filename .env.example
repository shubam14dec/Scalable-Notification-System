# API
PORT=3000

# Postgres (system of record; docker-compose maps it to host port 5433)
DATABASE_URL=postgres://postgres:postgres@localhost:5433/notifications

# Redis (queues, rate limits, dedupe, log buffer)
REDIS_HOST=localhost
REDIS_PORT=6379

# SMTP (Mailpit from docker-compose; UI at http://localhost:8025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=notifications@example.com

# Chaos: probability [0..1] that the primary email provider throws a transient
# error. Set to e.g. 0.5 to watch retries, circuit breaking and failover happen.
EMAIL_CHAOS_RATE=0

# Delivery worker concurrency per priority tier (per channel queue)
DELIVERY_CONCURRENCY_P0=30
DELIVERY_CONCURRENCY_P1=15
DELIVERY_CONCURRENCY_P2=5

# Global outbound pace per channel (jobs per second across all workers of a queue)
EMAIL_SENDS_PER_SEC=50
SMS_SENDS_PER_SEC=20
PUSH_SENDS_PER_SEC=100
INAPP_SENDS_PER_SEC=1000

# WebSocket gateway (in-app live push)
WS_PORT=3001

# HMAC secret for provider status webhooks (empty = verification disabled, dev only)
WEBHOOK_SIGNING_SECRET=dev-webhook-secret

# Prometheus endpoint of the worker process (/metrics); API serves its own on :3000
WORKER_METRICS_PORT=3002

# OpenTelemetry tracing (Jaeger UI from docker-compose: http://localhost:16686)
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Which priority tiers THIS worker process serves (default: all three).
# Run a dedicated transactional lane with WORKER_TIERS=p0 — bulk load in
# other processes can then never saturate P0's CPU/event loop.
WORKER_TIERS=p0,p1,p2

# Pipeline worker concurrency
TRIGGER_CONCURRENCY=20
FANOUT_CONCURRENCY=20
STATUS_CONCURRENCY=10

# Execution log batch writer
LOG_FLUSH_INTERVAL_MS=500
LOG_FLUSH_BATCH=500

# Tenant overflow (burst QoS): between 1x and HARD_LIMIT_MULTIPLIER x the
# tenant's rate limit, triggers are accepted but diverted to the overflow
# queue and trickled back in; beyond the hard cap the API returns 429.
HARD_LIMIT_MULTIPLIER=5
OVERFLOW_CONCURRENCY=5
OVERFLOW_REPLAY_PER_SEC=20

# ClickHouse (execution-log analytics store; Postgres keeps a copy too)
CLICKHOUSE_ENABLED=true
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=notifications
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse
