{
  "expo": {
    "name": "Asyncify Push Test",
    "slug": "asyncify-push-test",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#09090b"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "io.asyncify.pushtest",
      "googleServicesFile": "./google-services.json"
    },
    "ios": {
      "bundleIdentifier": "io.asyncify.pushtest",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "plugins": [
      "@react-native-firebase/app",
      [
        "expo-build-properties",
        {
          "android": {
            "extraMavenRepos": []
          },
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "26b76ed5-06a5-40da-adb1-9fa42997cb43"
      }
    }
  }
}
