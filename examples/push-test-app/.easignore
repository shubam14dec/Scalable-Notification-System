# EAS upload rules. When this file exists it REPLACES .gitignore for
# deciding what gets uploaded to the cloud builder — which lets
# google-services.json ride along to the build (the config plugin needs
# it) while staying out of git per .gitignore.
android/
ios/
node_modules/
.expo/
dist/
web-build/
# NOTE: *.tgz deliberately NOT ignored here (unlike .gitignore) — the packed
# @asyncify-hq/react-native tarball must reach the cloud builder, because the
# package's dist/ is git-ignored and a bare file:../../ dependency arrives
# empty on EAS.
*.log
.DS_Store
