{
  "name": "@asyncify-hq/react",
  "version": "0.3.0",
  "description": "Drop-in notification inbox for Asyncify — bell, unread badge, live WebSocket updates",
  "keywords": [
    "notifications",
    "inbox",
    "react",
    "notification-center",
    "asyncify",
    "bell"
  ],
  "homepage": "https://asyncify.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shubam14dec/Scalable-Notification-System.git",
    "directory": "packages/react"
  },
  "license": "MIT",
  "author": "Shubam Patil",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.tsx --format esm,cjs --dts --clean",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
