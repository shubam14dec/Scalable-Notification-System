{
  "name": "@asyncify-hq/agent",
  "version": "0.4.0",
  "description": "Agent SDK for Asyncify — receive normalized conversation events from any channel, reply, and fire notification workflows mid-conversation",
  "keywords": [
    "agents",
    "ai-agents",
    "conversations",
    "chat",
    "notifications",
    "asyncify"
  ],
  "homepage": "https://asyncify.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shubam14dec/Scalable-Notification-System.git",
    "directory": "packages/agent"
  },
  "license": "MIT",
  "author": "Shubam Patil",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  }
}
